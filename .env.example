# OpenLearning 环境变量配置
# 复制为 .env 并填入实际值

# ── LLM (必填) ──────────────────────────────────────────────
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://api.mimo.ai/v1

# ── 搜索 API (可选，无 key 则降级到免费源) ──────────────────
# Tavily: AI 优化搜索，国内可用，推荐 (tavily.com 免费 1000次/月)
TAVILY_API_KEY=
# SerpAPI: Google 搜索 (serpapi.com 免费 100次/月)
GOOGLE_API_KEY=
YOUTUBE_API_KEY=
GITHUB_TOKEN=

# ── LangSmith 可观测性 (可选) ───────────────────────────────
LANGSMITH_API_KEY=

# ── 数据库 & 输出 ───────────────────────────────────────────
OPENLEARNING_DB_PATH=data/openlearning.db
OPENLEARNING_OUTPUT_DIR=output
